# Frontend (React / Vite)
# Backend API Base URL (PHP CodeIgniter 4)
# 
# IMPORTANT: Using relative path (/api/v1) requires a reverse proxy in production.
# - Development: Vite dev server proxy forwards /api to the backend
# - Production: Hosting must proxy /api to the backend (same-origin)
# 
# This file is used for local development.
# Toggle API base URL by switching one of the lines below:
# - Relative (dev proxy): VITE_API_BASE_URL=/api/v1
# - Full URL (direct backend, requires CORS for localhost):
  VITE_API_BASE_URL=https://rbbphpremsana-test.azurewebsites.net/api/v1
# VITE_API_BASE_URL=/api/v1

# Development mode
VITE_DEV_MODE=true

# Feature flags (optional)
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_ANALYTICS=false

# Test credentials (development only - JSON array)
# Example: [{"email":"test@remsana.com","password":"Test1234!"}]
# WARNING: Never commit real credentials. Remove this in production.
VITE_TEST_CREDENTIALS=
