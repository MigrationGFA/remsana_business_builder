# Frontend (React / Vite)
# Backend API Base URL (PHP CodeIgniter 4)
# 
# IMPORTANT: Use relative path in development (Vite proxy handles it)
#            Use full URL in production (no proxy available)
# 
# THIS FILE (.env) = DEVELOPMENT ONLY
# Use relative path so Vite proxy can forward requests
VITE_API_BASE_URL=/api/v1

# Development mode
VITE_DEV_MODE=true

# Feature flags (optional)
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_ANALYTICS=false

# Test credentials (development only - JSON array)
# Example: [{"email":"test@remsana.com","password":"Test1234!"}]
# WARNING: Never commit real credentials. Remove this in production.
VITE_TEST_CREDENTIALS=
